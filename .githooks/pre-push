#!/usr/bin/env bash
set -euo pipefail

# Pre-push hook
# Runs the FULL quality suite (tests + build + lint)
# This ensures no broken code is pushed to production

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
CHECK_SCRIPT="$PROJECT_ROOT/scripts/check.py"

# Colors (respect NO_COLOR=1)
if [ -n "${NO_COLOR:-}" ]; then
    RED='' YELLOW='' GREEN='' BLUE='' NC=''
else
    RED='\033[0;31m'
    YELLOW='\033[0;33m'
    GREEN='\033[0;32m'
    BLUE='\033[0;34m'
    NC='\033[0m'
fi

# Detect delete-only push. Git provides "<local-ref> <local-sha> <remote-ref>
# <remote-sha>" on stdin for each ref (see `man githooks`, "pre-push"). For
# deletions, local-sha is the all-zero OID — 40 hex chars under SHA-1, 64
# under SHA-256, hence the length-agnostic regex. A push with no code
# content has nothing to validate.
#
# Drain the entire stdin (no `break`) so any future consumer below this
# loop sees the full refspec list. `while read` at EOF returns non-zero;
# bash treats that as the loop-terminator, not an `errexit` trigger — do
# not refactor to a pipe (the subshell + SIGPIPE interaction breaks this).
DELETE_ONLY=true
HAS_REFS=false
while read -r local_ref local_sha remote_ref remote_sha; do
    HAS_REFS=true
    if [[ ! "$local_sha" =~ ^0+$ ]]; then
        DELETE_ONLY=false
    fi
done

if [[ "$HAS_REFS" == true && "$DELETE_ONLY" == true ]]; then
    echo -e "${BLUE}ℹ  Delete-only push — skipping quality check.${NC}"
    exit 0
fi

echo -e "${BLUE}🚀 Preparing to push... Running full quality check${NC}"

if [ ! -f "$CHECK_SCRIPT" ]; then
    echo -e "${YELLOW}⚠  $CHECK_SCRIPT not found. Skipping full validation.${NC}"
    exit 0
fi

# Execute the full check.py without the --fast flag.
# This will run Vitest, Cargo tests, and the final production build.
if python3 "$CHECK_SCRIPT"; then
    echo -e "${GREEN}✅ Full suite passed. Pushing code to remote...${NC}"
    exit 0
else
    echo -e "${RED}❌ Push blocked! One or more checks failed.${NC}"
    exit 1
fi
